---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AppShowcase } from '../components/AppShowcase';
import { PlayStoreButton } from '../components/PlayStoreButton';

const features = [
  ['Spoken readout', 'Notif reads selected Android notifications aloud when your hands are busy.'],
  ['Per-app control', 'Set each app to read or mute so only useful notifications interrupt you.'],
  ['Bluetooth ready', 'Works with headphones, earbuds, and Bluetooth devices during everyday routines.'],
  ['Adjustable volume', 'Tune readout volume separately so spoken updates fit your environment.'],
  ['Custom limits', 'Control behavior and word limits to keep readouts short and practical.'],
  ['Lightweight setup', 'No account, no sign-in, and a simple setup path on Android.']
];

const privacyPoints = [
  'Notification logic runs on your device',
  'No cloud processing for notification readouts',
  'No account or sign-in required',
  'Notif does not scan installed apps'
];

const moments = ['Walking', 'Commuting', 'Working out', 'Driving', 'Multitasking'];
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout
  title="Notif - Private Spoken Notifications"
  description="Notif reads Android notifications aloud with privacy-first, on-device processing."
>
  <header class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <a class="flex items-center gap-3 font-bold" href={base}>
      <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-ink text-white">N</span>
      <span>Notif</span>
    </a>
    <nav class="hidden items-center gap-7 text-sm font-medium text-slate-600 sm:flex">
      <a class="hover:text-ink" href="#features">Features</a>
      <a class="hover:text-ink" href="#privacy">Privacy</a>
      <a class="hover:text-ink" href={`${base}privacy-policy/`}>Policy</a>
    </nav>
  </header>

  <main>
    <section class="mx-auto grid max-w-7xl items-center gap-12 px-6 pb-16 pt-10 lg:grid-cols-[0.9fr_1.1fr] lg:px-8 lg:pb-24 lg:pt-16">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-leaf">Private spoken notifications</p>
        <h1 class="mt-5 max-w-3xl text-5xl font-black leading-[1.02] text-ink sm:text-6xl lg:text-7xl">
          Listen to notifications hands-free.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          Notif turns Android notifications into spoken readouts while keeping the logic on your device. No cloud processing. No account. No sign-in.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <PlayStoreButton />
          <a
            class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-ink shadow-sm transition hover:-translate-y-0.5 hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-signal focus:ring-offset-2"
            href="#privacy"
          >
            See privacy approach
          </a>
        </div>
        <div class="mt-8 grid max-w-xl grid-cols-2 gap-3 text-sm text-slate-700 sm:grid-cols-4">
          {
            privacyPoints.map((point) => (
              <div class="rounded-lg border border-white/70 bg-white/70 p-3 shadow-sm backdrop-blur">
                {point}
              </div>
            ))
          }
        </div>
      </div>
      <div>
        <AppShowcase />
      </div>
    </section>

    <section id="features" class="bg-white/80 py-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-signal">Built for daily motion</p>
          <h2 class="mt-4 text-4xl font-black text-ink">The useful parts of your notifications, out loud.</h2>
        </div>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map(([title, body]) => (
              <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-bold text-ink">{title}</h3>
                <p class="mt-3 leading-7 text-slate-600">{body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="privacy" class="py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-leaf">Privacy first</p>
          <h2 class="mt-4 text-4xl font-black text-ink">Designed to speak notifications without turning them into cloud data.</h2>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            privacyPoints.map((point) => (
              <div class="rounded-lg border border-emerald-200 bg-white p-6 shadow-sm">
                <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-lg font-black text-leaf">✓</div>
                <p class="text-lg font-bold text-ink">{point}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-ink py-20 text-white">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-orange-300">Everyday moments</p>
            <h2 class="mt-4 text-4xl font-black">Stay updated without checking your screen.</h2>
          </div>
          <div class="flex flex-wrap gap-3">
            {
              moments.map((moment) => (
                <span class="rounded-md border border-white/15 bg-white/10 px-4 py-3 text-sm font-semibold">
                  {moment}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between lg:px-8">
    <p>© 2026 Notif. Private spoken notifications for Android.</p>
    <div class="flex flex-wrap gap-5">
      <a class="hover:text-ink" href={`${base}privacy-policy/`}>Privacy Policy</a>
      <a class="hover:text-ink" href="mailto:edward.devapps@gmail.com">Support</a>
      <a class="hover:text-ink" href="https://play.google.com/store/apps/details?id=com.app.android.notif" rel="noreferrer" target="_blank">Google Play</a>
    </div>
  </footer>
</BaseLayout>
