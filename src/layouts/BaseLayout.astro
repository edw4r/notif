---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  imageAlt?: string;
  structuredData?: Record<string, unknown>;
}

const { title, description, imageAlt, structuredData } = Astro.props;
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = new URL(canonicalPath, Astro.site);
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const imageUrl = new URL(`${base}assets/notif-settings.png`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#111827" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,400;6..144,500;6..144,600;6..144,700;6..144,800;6..144,900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={`${base}assets/notif-icon.png`} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="Notif" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <title>{title}</title>
    {
      structuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body class="font-sans text-ink antialiased">
    <slot />
  </body>
</html>
